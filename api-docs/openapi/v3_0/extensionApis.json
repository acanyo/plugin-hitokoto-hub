  "components" : {
    "schemas" : {
      "AddOperation" : {
        "required" : [ "op", "path", "value" ],
        "type" : "object",
        "properties" : {
          "op" : {
            "type" : "string",
            "enum" : [ "add" ]
          },
          "path" : {
            "pattern" : "^(/[^/~]*(~[01][^/~]*)*)*$",
            "type" : "string",
            "description" : "A JSON Pointer path pointing to the location to move/copy from.",
            "example" : "/a/b/c"
          },
          "value" : {
            "description" : "Value can be any JSON value"
          }
        }
      },
      "BatchCreateSentenceResult" : {
        "type" : "object",
        "properties" : {
          "failed" : {
            "type" : "integer",
            "format" : "int64"
          },
          "success" : {
            "type" : "integer",
            "format" : "int64"
          },
          "total" : {
            "type" : "integer",
            "format" : "int64"
          }
        }
      },
      "Category" : {
        "required" : [ "apiVersion", "kind", "metadata", "spec" ],
        "type" : "object",
        "properties" : {
          "apiVersion" : {
            "type" : "string"
          },
          "kind" : {
            "type" : "string"
          },
          "metadata" : {
            "$ref" : "#/components/schemas/Metadata"
          },
          "spec" : {
            "$ref" : "#/components/schemas/CategorySpec"
          },
          "status" : {
            "$ref" : "#/components/schemas/CategoryStatus"
          }
        }
      },
      "CategoryDistribution" : {
        "type" : "object",
        "properties" : {
          "categoryName" : {
            "type" : "string",
            "description" : "分类 metadata name"
          },
          "count" : {
            "type" : "integer",
            "description" : "句子数量",
            "format" : "int64"
          },
          "displayName" : {
            "type" : "string",
            "description" : "分类显示名称"
          },
          "notPublishedCount" : {
            "type" : "integer",
            "description" : "未公开的句子数量",
            "format" : "int64"
          },
          "publishedCount" : {
            "type" : "integer",
            "description" : "公开的句子数量",
            "format" : "int64"
          }
        },
        "description" : "各分类句子数量分布"
      },
      "CategoryItem" : {
        "type" : "object",
        "properties" : {
          "description" : {
            "type" : "string",
            "description" : "分类描述"
          },
          "displayName" : {
            "type" : "string",
            "description" : "分类显示名称"
          },
          "name" : {
            "type" : "string",
            "description" : "分类标识"
          },
          "sentenceCount" : {
            "type" : "integer",
            "description" : "句子数量",
            "format" : "int64"
          }
        }
      },
      "CategoryList" : {
        "required" : [ "first", "hasNext", "hasPrevious", "items", "last", "page", "size", "total", "totalPages" ],
        "type" : "object",
        "properties" : {
          "first" : {
            "type" : "boolean",
            "description" : "Indicates whether current page is the first page."
          },
          "hasNext" : {
            "type" : "boolean",
            "description" : "Indicates whether current page has previous page."
          },
          "hasPrevious" : {
            "type" : "boolean",
            "description" : "Indicates whether current page has previous page."
          },
          "items" : {
            "type" : "array",
            "description" : "A chunk of items.",
            "items" : {
              "$ref" : "#/components/schemas/Category"
            }
          },
          "last" : {
            "type" : "boolean",
            "description" : "Indicates whether current page is the last page."
          },
          "page" : {
            "type" : "integer",
            "description" : "Page number, starts from 1. If not set or equal to 0, it means no pagination.",
            "format" : "int32"
          },
          "size" : {
            "type" : "integer",
            "description" : "Size of each page. If not set or equal to 0, it means no pagination.",
            "format" : "int32"
          },
          "total" : {
            "type" : "integer",
            "description" : "Total elements.",
            "format" : "int64"
          },
          "totalPages" : {
            "type" : "integer",
            "description" : "Indicates total pages.",
            "format" : "int64"
          }
        }
      },
      "CategorySpec" : {
        "required" : [ "name" ],
        "type" : "object",
        "properties" : {
          "description" : {
            "maxLength" : 200,
            "type" : "string",
